generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Supavisor transaction pooler for app runtime (port 6543)
  url       = env("DATABASE_URL")
  // Supavisor session pooler for schema operations on IPv4 networks (port 5432)
  directUrl = env("DIRECT_URL")
}

// ─── Better Auth tables ───────────────────────────────────────────

model User {
  id                      String                      @id @default(cuid())
  name                    String
  email                   String                      @unique
  emailVerified           Boolean                     @default(false)
  image                   String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  sessions                Session[]
  accounts                Account[]
  posts                   Post[]
  researchRuns            ResearchRun[]
  generationJobs          GenerationJob[]
  topics                  Topic[]
  writingStyles           WritingStyle[]
  modelConfigs            ModelConfig[]
  settings                UserSettings?
  contentStrategy         ContentStrategy?
  performanceSnapshots    SocialPerformanceSnapshot[]
  engagementOpportunities EngagementOpportunity[]
  growthExperiments       GrowthExperiment[]
  strategyRecommendations StrategyRecommendation[]
  brandSettings           BrandSettings?
  visualAssets            PostVisualAsset[]
  ownedRepositories       OwnedRepository[]
  projectFacts            ProjectFact[]
  creatorRelationships    CreatorRelationship[]
  distributionWorkflows   DistributionWorkflow[]
  contentSignals          ContentSignal[]
  campaigns               Campaign[]
  campaignMetricSnapshots CampaignMetricSnapshot[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Domain ───────────────────────────────────────────────────────

model UserSettings {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  timezone         String  @default("Asia/Dubai")
  postsPerDay      Int     @default(12)
  qualityThreshold Float   @default(8.0)
  firstPostHour    Int     @default(6)
  lastPostHour     Int     @default(21)
  defaultPlatforms String  @default("x,linkedin") // comma-separated
  autoGenerate     Boolean @default(false)
}

/// Audience positioning, editorial pillars, owned projects, and target content mix.
model ContentStrategy {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetAudience String
  positioning    String
  pillarsJson    String
  projectsJson   String
  contentMixJson String
  excludedTopics String   @default("") // newline-separated exclusions
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Topic {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  keywords    String   @default("") // comma-separated
  active      Boolean  @default(true)
  weight      Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]

  @@unique([userId, slug])
  @@index([userId, active])
}

model WritingStyle {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  isDefault    Boolean  @default(false)
  systemPrompt String
  rules        String   @default("") // newline-separated rules
  examples     String   @default("") // few-shot examples
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posts        Post[]
}

model ModelConfig {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  provider    String   @default("deepseek")
  model       String   @default("deepseek-chat")
  baseUrl     String   @default("https://api.deepseek.com")
  temperature Float    @default(0.7)
  maxTokens   Int      @default(2048)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// A GitHub repository owned by the user and monitored for product evidence.
/// Sync is read-only; DevPulse never mutates the upstream repository.
model OwnedRepository {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String
  name          String
  owner         String
  repo          String
  fullName      String
  url           String
  defaultBranch String             @default("main")
  active        Boolean            @default(true)
  syncStatus    String             @default("never_synced") // never_synced | running | completed | failed
  lastSyncedAt  DateTime?
  lastCommitSha String?
  lastError     String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  changes       RepositoryChange[]
  facts         ProjectFact[]

  @@unique([userId, fullName])
  @@index([userId, active])
}

/// Immutable evidence discovered during an incremental repository sync.
model RepositoryChange {
  id                String          @id @default(cuid())
  repositoryId      String
  repository        OwnedRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  externalId        String
  kind              String // commit | pull_request | release
  title             String
  summary           String?
  url               String
  author            String?
  occurredAt        DateTime
  changedFilesJson  String          @default("[]")
  additions         Int?
  deletions         Int?
  rawJson           String?
  significanceScore Int             @default(0)
  status            String          @default("candidate") // candidate | noise | fact_created
  noiseReason       String?
  createdAt         DateTime        @default(now())
  fact              ProjectFact?

  @@unique([repositoryId, kind, externalId])
  @@index([repositoryId, occurredAt])
  @@index([repositoryId, status])
}

/// A human-reviewed, evidence-backed claim that may be used by generation.
model ProjectFact {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositoryId  String
  repository    OwnedRepository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  changeId      String?           @unique
  change        RepositoryChange? @relation(fields: [changeId], references: [id], onDelete: SetNull)
  projectId     String
  title         String
  claim         String
  evidenceJson  String
  sourceUrl     String
  confidence    Float             @default(0.75)
  reviewStatus  String            @default("pending") // pending | approved | rejected
  useCount      Int               @default(0)
  lastUsedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  campaignItems CampaignItem[]

  @@index([userId, reviewStatus, createdAt])
  @@index([repositoryId, reviewStatus])
}

model Source {
  id            String       @id @default(cuid())
  provider      String // active: project | github | arxiv | huggingface | rss | hackernews | reddit
  externalId    String
  title         String
  url           String
  summary       String?
  score         Float        @default(0)
  rawJson       String? // stored JSON
  fetchedAt     DateTime     @default(now())
  researchRunId String?
  researchRun   ResearchRun? @relation(fields: [researchRunId], references: [id], onDelete: SetNull)
  posts         PostSource[]

  @@unique([provider, externalId])
  @@index([fetchedAt])
  @@index([researchRunId])
}

model ResearchRun {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         String          @default("pending") // pending | running | completed | failed
  sourcesFound   Int             @default(0)
  topicsRanked   String? // JSON array of ranked topics
  error          String?
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  sources        Source[]
  posts          Post[]
  generationJobs GenerationJob[]
}

model Post {
  id                           String                      @id @default(cuid())
  userId                       String
  user                         User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform                     String                      @default("both") // both | x | linkedin (legacy single-platform)
  format                       String                      @default("dual") // dual | single | thread | longform | tip | comparison
  title                        String?
  content                      String // primary body (LinkedIn long-form for dual posts)
  contentLinkedIn              String? // explicit LinkedIn copy (falls back to content)
  threadJson                   String? // JSON string[] — X thread, each item ≤280 chars
  status                       String                      @default("draft") // draft | pending_review | approved | scheduled | ready | posted_manually | skipped | rejected | failed
  contentHash                  String
  topicId                      String?
  topic                        Topic?                      @relation(fields: [topicId], references: [id], onDelete: SetNull)
  writingStyleId               String?
  writingStyle                 WritingStyle?               @relation(fields: [writingStyleId], references: [id], onDelete: SetNull)
  researchRunId                String?
  researchRun                  ResearchRun?                @relation(fields: [researchRunId], references: [id], onDelete: SetNull)
  angle                        String?
  contentType                  String? // project_lesson | architecture_breakdown | evidence_opinion | experiment_benchmark | curated_discovery
  hook                         String?
  // Optional screenshot for manual attach when posting on X/LinkedIn
  needsImage                   Boolean                     @default(false)
  imagePath                    String? // public-relative path e.g. /screenshots/abc.png
  imageSourceUrl               String? // page that was captured
  imageCaption                 String?
  imageSkipReason              String? // why no image was attached
  // Quality scores 0-10
  scoreNovelty                 Float?
  scoreAccuracy                Float?
  scoreHook                    Float?
  scoreReadability             Float?
  scoreVirality                Float?
  scoreTechnical               Float?
  scoreEngagement              Float?
  scoreOverall                 Float?
  citationsJson                String? // JSON array of {title,url}
  rejectionReason              String?
  postedManuallyAt             DateTime?
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @updatedAt
  sources                      PostSource[]
  schedule                     Schedule?
  readinessJobs                ReadinessJob[]
  performanceSnapshots         SocialPerformanceSnapshot[]
  experimentVariantId          String?
  experimentVariant            GrowthExperimentVariant?    @relation(fields: [experimentVariantId], references: [id], onDelete: SetNull)
  experimentEligible           Boolean                     @default(true)
  generationSnapshotJson       String? // immutable Phase 5 strategy/brief/source snapshot used to generate this post
  recommendedMediaType         String                      @default("branded_visual") // text_only | branded_visual | carousel
  mediaType                    String                      @default("text_only") // actual manually published asset type
  recommendedMediaTypeX        String                      @default("branded_visual")
  recommendedMediaTypeLinkedIn String                      @default("branded_visual")
  mediaTypeX                   String                      @default("text_only")
  mediaTypeLinkedIn            String                      @default("text_only")
  visualAssets                 PostVisualAsset[]
  distributionWorkflows        DistributionWorkflow[]
  contentSignals               ContentSignal[]
  campaignItem                 CampaignItem?

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([contentHash])
  @@index([platform])
  @@index([experimentVariantId])
}

model BrandSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String
  handle          String   @default("")
  tagline         String   @default("Building AI developer tools in public")
  accentColor     String   @default("#22d3ee")
  backgroundColor String   @default("#07111f")
  textColor       String   @default("#f8fafc")
  footerText      String   @default("Local AI · LLM Systems · Product Engineering")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PostVisualAsset {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId            String
  post              Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  kind              String // portrait_card | linkedin_carousel
  targetPlatform    String   @default("both") // both | x | linkedin
  template          String   @default("technical_grid")
  status            String   @default("rendering") // rendering | completed | failed
  briefJson         String
  filePath          String?
  storageKey        String?
  previewPath       String?
  previewStorageKey String?
  mimeType          String?
  width             Int      @default(1200)
  height            Int      @default(1500)
  pageCount         Int      @default(1)
  altText           String?
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([postId, status])
}

/// A controlled content experiment. A post is assigned to exactly one variant
/// before writing so later performance can be attributed to the actual brief.
model GrowthExperiment {
  id                  String                    @id @default(cuid())
  userId              String
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  hypothesis          String
  platform            String                    @default("x") // x | linkedin
  dimension           String // hook_pattern | ending_pattern | x_format
  primaryMetric       String                    @default("engagement_rate")
  minSamplePerVariant Int                       @default(3)
  status              String                    @default("draft") // draft | active | paused | completed
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  variants            GrowthExperimentVariant[]
  recommendations     StrategyRecommendation[]

  @@index([userId, status, createdAt])
}

model GrowthExperimentVariant {
  id                 String                   @id @default(cuid())
  experimentId       String
  experiment         GrowthExperiment         @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  key                String
  label              String
  configJson         String
  createdAt          DateTime                 @default(now())
  posts              Post[]
  recommendationWins StrategyRecommendation[] @relation("WinningVariant")

  @@unique([experimentId, key])
  @@index([experimentId])
}

/// Evidence-backed change proposed by an experiment. Only `applied` rows are
/// allowed to influence future generation; recommendations are never applied silently.
model StrategyRecommendation {
  id                 String                   @id @default(cuid())
  userId             String
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  experimentId       String?
  experiment         GrowthExperiment?        @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  winnerVariantId    String?
  winnerVariant      GrowthExperimentVariant? @relation("WinningVariant", fields: [winnerVariantId], references: [id], onDelete: SetNull)
  dimension          String
  platform           String
  status             String                   @default("pending") // pending | applied | rejected | superseded
  proposedConfigJson String
  evidenceJson       String
  rationale          String
  createdAt          DateTime                 @default(now())
  decidedAt          DateTime?

  @@index([userId, status, createdAt])
  @@index([experimentId])
}

/// Manually recorded cumulative platform metrics. Multiple snapshots preserve change over time.
model SocialPerformanceSnapshot {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId          String
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform        String // x | linkedin
  impressions     Int      @default(0)
  likes           Int      @default(0)
  replies         Int      @default(0)
  reposts         Int      @default(0) // reposts on X, shares on LinkedIn
  saves           Int      @default(0)
  profileVisits   Int      @default(0)
  linkClicks      Int      @default(0)
  followersBefore Int?
  followersAfter  Int?
  notes           String?
  capturedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([userId, capturedAt])
  @@index([postId, platform, capturedAt])
}

/// Conversation worth joining. X search can ingest these; LinkedIn can be entered manually.
model EngagementOpportunity {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       String // x | linkedin
  url            String
  externalId     String?
  author         String?
  topic          String?
  context        String
  suggestedReply String?
  status         String               @default("new") // new | replied | dismissed
  source         String               @default("manual") // manual | x_search
  priorityScore  Int                  @default(50)
  priorityReason String?
  repliedAt      DateTime?
  outcome        String?
  relationshipId String?
  relationship   CreatorRelationship? @relation(fields: [relationshipId], references: [id], onDelete: SetNull)
  contentSignals ContentSignal[]
  discoveredAt   DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([userId, platform, url])
  @@index([userId, status, discoveredAt])
  @@index([userId, status, priorityScore])
  @@index([relationshipId])
}

/// A creator or engineer the user repeatedly engages with manually.
model CreatorRelationship {
  id                String                  @id @default(cuid())
  userId            String
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          String // x | linkedin
  handle            String
  displayName       String?
  profileUrl        String?
  topicsJson        String                  @default("[]")
  notes             String?
  status            String                  @default("active") // active | watch | muted
  priorityScore     Int                     @default(50)
  interactionCount  Int                     @default(0)
  replyCount        Int                     @default(0)
  lastInteractionAt DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  opportunities     EngagementOpportunity[]

  @@unique([userId, platform, handle])
  @@index([userId, status, priorityScore])
}

/// Platform-specific manual distribution checklist for a generated post.
model DistributionWorkflow {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId             String
  post               Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform           String // x | linkedin
  status             String    @default("planned") // planned | prepared | published | follow_up | completed
  assetReadyAt       DateTime?
  preEngagedAt       DateTime?
  publishedAt        DateTime?
  commentsReviewedAt DateTime?
  metricsCapturedAt  DateTime?
  completedAt        DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([postId, platform])
  @@index([userId, status, updatedAt])
}

/// A question, objection, or idea captured from a real audience conversation.
model ContentSignal {
  id            String                 @id @default(cuid())
  userId        String
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   EngagementOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  postId        String?
  post          Post?                  @relation(fields: [postId], references: [id], onDelete: SetNull)
  kind          String                 @default("question") // question | objection | idea
  text          String
  sourceUrl     String?
  status        String                 @default("saved") // saved | used | dismissed
  createdAt     DateTime               @default(now())
  usedAt        DateTime?
  campaignItems CampaignItem[]

  @@index([userId, status, createdAt])
  @@index([opportunityId])
}

/// A goal-driven sequence of evidence-backed posts for one owned product.
model Campaign {
  id                   String                   @id @default(cuid())
  userId               String
  user                 User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  projectId            String
  projectName          String
  goal                 String // followers | github_stars | awareness | beta_users | credibility
  goalMetric           String
  goalTarget           Int?
  baselineValue        Int?
  platforms            String                   @default("x,linkedin")
  status               String                   @default("draft") // draft | active | paused | completed
  startAt              DateTime
  endAt                DateTime
  ctaMode              String                   @default("follow") // follow | repository | try_product | join_waitlist | question
  ctaTextX             String?
  ctaTextLinkedIn      String?
  destinationUrl       String?
  notes                String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  items                CampaignItem[]
  performanceSnapshots CampaignMetricSnapshot[]

  @@index([userId, status, startAt])
  @@index([userId, projectId])
}

/// One narrative stage in a campaign. It links to a regular Post only after drafting.
model CampaignItem {
  id              String         @id @default(cuid())
  campaignId      String
  campaign        Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sequence        Int
  stage           String // problem | decision | implementation | progress | audience | proof | recap
  label           String
  purpose         String
  status          String         @default("planned") // planned | blocked | drafted | skipped
  scheduledFor    DateTime
  postId          String?        @unique
  post            Post?          @relation(fields: [postId], references: [id], onDelete: SetNull)
  evidenceKind    String // project_context | project_fact | audience_signal | fact_bundle
  projectFactId   String?
  projectFact     ProjectFact?   @relation(fields: [projectFactId], references: [id], onDelete: SetNull)
  contentSignalId String?
  contentSignal   ContentSignal? @relation(fields: [contentSignalId], references: [id], onDelete: SetNull)
  evidenceJson    String
  ctaJson         String         @default("{}")
  blockReason     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([campaignId, sequence])
  @@index([campaignId, status, scheduledFor])
  @@index([projectFactId])
  @@index([contentSignalId])
}

/// Manually captured destination metrics such as GitHub stars or waitlist users.
model CampaignMetricSnapshot {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  metric     String
  value      Int
  notes      String?
  capturedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([campaignId, metric, capturedAt])
  @@index([userId, capturedAt])
}

model PostSource {
  postId   String
  sourceId String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@id([postId, sourceId])
}

model Schedule {
  id           String   @id @default(cuid())
  postId       String   @unique
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  scheduledFor DateTime
  slotIndex    Int // 0-11 for the 12 daily slots
  status       String   @default("pending") // pending | ready | posted_manually | skipped | cancelled | missed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([scheduledFor, status])
}

/// Tracks human approval + readiness for manual posting (never auto-posts to social APIs).
model ReadinessJob {
  id         String    @id @default(cuid())
  postId     String
  post       Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform   String
  status     String    @default("awaiting_approval") // awaiting_approval | approved | ready | posted_manually | cancelled
  approvedAt DateTime?
  readyAt    DateTime?
  postedAt   DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
}

model GenerationJob {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  researchRunId String?
  researchRun   ResearchRun? @relation(fields: [researchRunId], references: [id], onDelete: SetNull)
  status        String       @default("pending") // pending | researching | planning | writing | scoring | scheduling | completed | failed
  targetCount   Int          @default(12)
  producedCount Int          @default(0)
  logsJson      String       @default("[]")
  error         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  completedAt   DateTime?

  @@index([userId, status])
}

model PromptVersion {
  id        String   @id @default(cuid())
  key       String // writer | editor | scorer | planner
  version   Int
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([key, version])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  postId     String?
  platform   String
  metric     String // likes | reposts | replies | impressions | clicks
  value      Float
  recordedAt DateTime @default(now())

  @@index([postId])
  @@index([recordedAt])
}
