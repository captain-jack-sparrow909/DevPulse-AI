DATABASE_URL="file:./dev.db"
# For Supabase/Postgres later:
# DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

BETTER_AUTH_SECRET="generate-a-long-random-secret-at-least-32-chars"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# DeepSeek (https://platform.deepseek.com) — post writing
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# ---------------------------------------------------------------------------
# X / Twitter — RESEARCH ONLY (never used to post)
# Prefer a read-only Bearer token. Paid API tiers may be required for search.
# DevPulse will NEVER call tweet/create or LinkedIn share endpoints.
# ---------------------------------------------------------------------------
X_BEARER_TOKEN=""
# Optional aliases (read-only). Do not put write access tokens here.
# X_API_KEY is only used as a bearer if it does not look like an LLM key (xai-...).
X_API_KEY=""
X_API_SECRET=""

# LinkedIn — not used for posting. Manual post only. Keys optional/unused for write.
LINKEDIN_ACCESS_TOKEN=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Protects /api/cron/slot (Authorization: Bearer …)
CRON_SECRET="generate-a-long-random-secret"
