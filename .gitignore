# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Environment & secrets (never commit real keys) ────────
.env
.env.*
!.env.example
!**/.env.example

# ── Next.js / build ───────────────────────────────────────
.next/
out/
build/
dist/
.turbo/
*.tsbuildinfo

# ── Databases ─────────────────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite3
apps/web/prisma/*.db
apps/web/prisma/*.db-journal

# ── Playwright screenshots (keep directory via .gitkeep) ──
apps/web/public/screenshots/*
!apps/web/public/screenshots/.gitkeep

# ── Logs & debug ──────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS / editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/*
!.vscode/extensions.json

# ── Deploy / local tooling ────────────────────────────────
.vercel
.cache/
coverage/
tmp/
temp/
*.local

# ── Playwright browser downloads (if stored in-repo) ──────
/ms-playwright/
playwright-report/
test-results/
